{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tvl-lang.org/schemas/tvl-configuration.schema.json",
  "title": "TVL Configuration",
  "type": "object",
  "required": ["assignments"],
  "properties": {
    "config_id": { "type": "string" },
    "module_id": { "type": "string" },
    "module_version": { "type": ["string", "number"] },
    "assignments": {
      "type": "object",
      "description": "TVAR assignments (may be nested)"
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
